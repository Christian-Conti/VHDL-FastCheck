#!/usr/bin/env bash
set -euo pipefail

NIX_PROFILE="$HOME/.nix-profile/etc/profile.d/nix.sh"

nix_ghdl_path() {
    # Returns the ghdl binary path if Nix-installed GHDL is present
    if [ -f "$NIX_PROFILE" ]; then
        # shellcheck disable=SC1090
        source "$NIX_PROFILE"
    fi
    command -v ghdl 2>/dev/null || true
}

GHDL_BIN="$(nix_ghdl_path)"
if [ -n "$GHDL_BIN" ] && "$GHDL_BIN" --version &>/dev/null; then
    echo "[INFO] GHDL is already installed at $GHDL_BIN. Skipping."
    exit 0
fi

if ! command -v nix-env &>/dev/null; then
    echo "[INFO] Nix not found. Installing Nix (no-daemon, no root required)..."
    curl -fsSL https://nixos.org/nix/install | sh -s -- --no-daemon || {
        echo "[ERROR] Nix installation failed."
        exit 1
    }
    echo "[INFO] Nix installed."
fi

# Source Nix into the current shell session
if [ -f "$NIX_PROFILE" ]; then
    # shellcheck disable=SC1090
    source "$NIX_PROFILE"
else
    echo "[ERROR] Nix profile not found at $NIX_PROFILE after installation."
    exit 1
fi

echo "[INFO] Installing GHDL via Nix (this may take a few minutes on first run)..."
nix-env -iA nixpkgs.ghdl || {
    echo "[ERROR] Failed to install GHDL via Nix."
    exit 1
}

GHDL_BIN="$(nix_ghdl_path)"
if [ -z "$GHDL_BIN" ] || ! "$GHDL_BIN" --version &>/dev/null; then
    echo "[ERROR] GHDL installed but not functional. Check Nix setup."
    exit 1
fi

echo "[INFO] GHDL successfully installed: $("$GHDL_BIN" --version | head -1)"
SHELL_RC="$HOME/.bashrc"
if [ -n "${ZSH_VERSION:-}" ] || [[ "$SHELL" == *"zsh"* ]]; then
    SHELL_RC="$HOME/.zshrc"
fi

NIX_SOURCE_LINE=". \"$NIX_PROFILE\""
if ! grep -qF "$NIX_SOURCE_LINE" "$SHELL_RC" 2>/dev/null; then
    echo "[INFO] Adding Nix to $SHELL_RC"
    printf '\n# Added by GHDL setup script (Nix)\n%s\n' "$NIX_SOURCE_LINE" >> "$SHELL_RC"
    echo "[WARN] Run 'source $SHELL_RC' or restart your terminal for GHDL to be available in new sessions."
else
    echo "[INFO] Nix already sourced in $SHELL_RC."
fi

exit 0
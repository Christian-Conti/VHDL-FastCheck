#!/usr/bin/env bash
set -euo pipefail

PREFIX="${PREFIX:-$HOME/.local}"
LIBS_DIR="$PREFIX/lib/gnat13"
GHDL_RELEASE_URL="https://github.com/ghdl/ghdl/releases/download/v6.0.0/ghdl-gcc-6.0.0-ubuntu24.04-x86_64.tar.gz"
TMP_DIR="/tmp/ghdl_install_$$"


append_to_rc() {
    local line="$1"
    local rc="$HOME/.bashrc"
    [ -n "${ZSH_VERSION:-}" ] || [[ "$SHELL" == *"zsh"* ]] && rc="$HOME/.zshrc"
    if ! grep -qF "$line" "$rc" 2>/dev/null; then
        printf '\n# Added by GHDL setup script\n%s\n' "$line" >> "$rc"
        echo "[WARN] Added to $rc — run 'source $rc' or restart your terminal."
    fi
}

if [ -x "$PREFIX/bin/ghdl" ] && "$PREFIX/bin/ghdl" --version &>/dev/null; then
    echo "[INFO] GHDL already installed and functional. Skipping."
    exit 0
fi

mkdir -p "$TMP_DIR" "$PREFIX" "$LIBS_DIR"

echo "[INFO] Downloading pre-built GHDL (gcc backend)..."
curl -fsSL -o "$TMP_DIR/ghdl.tar.gz" "$GHDL_RELEASE_URL" || {
    echo "[ERROR] Failed to download GHDL."
    rm -rf "$TMP_DIR"; exit 2
}
tar -xzf "$TMP_DIR/ghdl.tar.gz" -C "$PREFIX" --strip-components=1 || {
    echo "[ERROR] Failed to extract GHDL archive."
    rm -rf "$TMP_DIR"; exit 3
}

pushd "$TMP_DIR" > /dev/null
apt-get download libgnat-13 2>/dev/null || {
    echo "[ERROR] apt-get download failed. Is 'universe' enabled? Try:"
    echo "        sudo add-apt-repository universe"
    rm -rf "$TMP_DIR"; exit 4
}
DEB_FILE=$(ls libgnat-13_*.deb 2>/dev/null | head -1)
if [ -z "$DEB_FILE" ]; then
    echo "[ERROR] libgnat-13 .deb not found after download."
    rm -rf "$TMP_DIR"; exit 5
fi
echo "[INFO] Extracting $DEB_FILE to $LIBS_DIR..."
dpkg-deb -x "$DEB_FILE" "$TMP_DIR/gnat_extract"
# Copy the actual .so files
find "$TMP_DIR/gnat_extract" -name "libgnat*.so*" -exec cp -P {} "$LIBS_DIR/" \;
popd > /dev/null

export LD_LIBRARY_PATH="$LIBS_DIR${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
if ! "$PREFIX/bin/ghdl" --version &>/dev/null; then
    echo "[ERROR] GHDL still not functional after installing libgnat-13."
    rm -rf "$TMP_DIR"; exit 6
fi
echo "[INFO] GHDL OK: $("$PREFIX/bin/ghdl" --version | head -1)"

append_to_rc "export PATH=\"$PREFIX/bin:\$PATH\""
append_to_rc "export LD_LIBRARY_PATH=\"$LIBS_DIR\${LD_LIBRARY_PATH:+:\$LD_LIBRARY_PATH}\""

rm -rf "$TMP_DIR"
echo "[INFO] Done. GHDL installed to $PREFIX/bin, libs in $LIBS_DIR."
exit 0
#!/usr/bin/env bash
set -euo pipefail

PREFIX="${PREFIX:-$HOME/.local}"
NVC_VERSION="1.19.3"
NVC_TAR_URL="https://github.com/nickg/nvc/releases/download/r${NVC_VERSION}/nvc-${NVC_VERSION}.tar.gz"
TMP_DIR="/tmp/nvc_install_$$"

append_to_rc() {
    local line="$1"
    local rc="$HOME/.bashrc"
    [[ "$SHELL" == *"zsh"* ]] && rc="$HOME/.zshrc"
    grep -qF "$line" "$rc" 2>/dev/null || printf '\n# Added by NVC setup script\n%s\n' "$line" >> "$rc"
}

if command -v nvc &>/dev/null && nvc --version &>/dev/null; then
    echo "[INFO] NVC already installed: $(nvc --version | head -1). Skipping."
    exit 0
fi

# Ensure Conda is in PATH and explicitly lock the path to the 'ms' environment
if ! command -v conda >/dev/null 2>&1; then
    export PATH="$HOME/miniconda3/bin:$PATH"
fi
CONDA_BASE_PATH="$(conda info --base 2>/dev/null || echo "$HOME/miniconda3")"
CONDA_PREFIX_PATH="$CONDA_BASE_PATH/envs/ms"

mkdir -p "$TMP_DIR" "$PREFIX"

echo "[INFO] Downloading NVC ${NVC_VERSION} source..."
curl -fsSL -o "$TMP_DIR/nvc.tar.gz" "$NVC_TAR_URL"

tar -xzf "$TMP_DIR/nvc.tar.gz" -C "$TMP_DIR"

SRC_DIR="$TMP_DIR/nvc-${NVC_VERSION}"
BUILD_DIR="$SRC_DIR/build"

echo "[INFO] Configuring NVC..."
LLVM_CONFIG=$(find "$CONDA_PREFIX_PATH/bin" -name "llvm-config*" | head -1)
[ -z "$LLVM_CONFIG" ] && LLVM_CONFIG=$(command -v llvm-config 2>/dev/null || true)
[ -z "$LLVM_CONFIG" ] && { echo "[ERROR] llvm-config not found."; rm -rf "$TMP_DIR"; exit 4; }
echo "[INFO] Using LLVM: $LLVM_CONFIG ($(${LLVM_CONFIG} --version))"

export PKG_CONFIG_PATH="$CONDA_PREFIX_PATH/lib/pkgconfig:${PKG_CONFIG_PATH:-}"
export CFLAGS="-I$CONDA_PREFIX_PATH/include"
export LDFLAGS="-L$CONDA_PREFIX_PATH/lib -Wl,-rpath,$CONDA_PREFIX_PATH/lib"

# Enforce out-of-source build
mkdir -p "$BUILD_DIR"
cd "$BUILD_DIR"

../configure \
    --prefix="$PREFIX" \
    --with-llvm="$LLVM_CONFIG" \
    --disable-verilog \
    2>&1 | tail -5

echo "[INFO] Building NVC (this takes ~2 minutes)..."
make -j"$(nproc)" 2>&1 | tail -5

make install

cd /
rm -rf "$TMP_DIR"

nvc --version &>/dev/null || { echo "[ERROR] NVC installed but not functional."; exit 5; }
echo "[INFO] NVC ready: $(nvc --version | head -1)"

append_to_rc "export PATH=\"$PREFIX/bin:\$PATH\""

exit 0

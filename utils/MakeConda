#!/usr/bin/env bash
set -euo pipefail

# Installer: Miniconda + conda env 'ms'
on_exit() {
  local rc=$?
  if [ $rc -ne 0 ]; then
    err "Installation failed (exit code $rc)"
  fi
}
trap on_exit EXIT

ENV_NAME="ms"
MINICONDA_DIR="${HOME}/miniconda3"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REQUIREMENTS_FILE="${REQUIREMENTS_FILE:-${SCRIPT_DIR}/python-requirements.txt}"

info() { :; }
warn() { :; }
err() { echo "[ERROR] $*" >&2; }

download_file() {
  local url="$1" out="$2"
  if command -v wget >/dev/null 2>&1; then
    wget -q "$url" -O "$out"
  elif command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url" -o "$out"
  else
    err "Neither wget nor curl is available..."
    return 1
  fi
}

glibc_version() {
  local ver
  ver="$(ldd --version 2>&1 | head -1 | grep -oE '[0-9]+\.[0-9]+$')"
  local major minor
  major="${ver%%.*}"; minor="${ver##*.}"
  echo $(( major * 1000 + minor ))
}

ensure_conda() {
  if command -v conda >/dev/null 2>&1; then
    eval "$(conda shell.bash hook)"
    return 0
  fi

  if [[ ! -x "${MINICONDA_DIR}/bin/conda" ]]; then
    local installer="/tmp/miniconda_installer.sh" arch glibc_ver suffix url
    arch="$(uname -m)"
    glibc_ver="$(glibc_version)"
    if (( glibc_ver >= 2028 )); then suffix="latest"; else suffix="py39_4.12.0"; fi
    case "$arch" in
      x86_64)  url="https://repo.anaconda.com/miniconda/Miniconda3-${suffix}-Linux-x86_64.sh" ;;
      aarch64) url="https://repo.anaconda.com/miniconda/Miniconda3-${suffix}-Linux-aarch64.sh" ;;
      *) err "Unsupported architecture: $arch"; return 1 ;;
    esac

    download_file "$url" "$installer"
    bash "$installer" -b -p "$MINICONDA_DIR"
    rm -f "$installer"
  fi

  export PATH="${MINICONDA_DIR}/bin:${PATH}"
  eval "$("${MINICONDA_DIR}/bin/conda" shell.bash hook)"
}

configure_conda_channels() {
  local channels
  channels="$(conda config --show channels 2>/dev/null || true)"
  if grep -qF -- "- defaults" <<<"$channels"; then
    conda config --remove channels defaults || true
  fi
  if ! grep -qF -- "- conda-forge" <<<"$channels"; then
    conda config --add channels conda-forge
  fi
  conda config --set channel_priority strict
}

accept_conda_tos_if_supported() {
  if conda tos --help >/dev/null 2>&1; then
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main >/dev/null 2>&1 || true
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r >/dev/null 2>&1 || true
  fi
}

init_conda_shell() {
  local user_shell rc_file
  user_shell="$(basename "${SHELL:-bash}")"
  case "${user_shell}" in
    bash) rc_file="${HOME}/.bashrc" ;;
    zsh)  rc_file="${HOME}/.zshrc" ;;
    fish) rc_file="${HOME}/.config/fish/config.fish" ;;
    *)    rc_file="${HOME}/.${user_shell}rc" ;;
  esac
  if conda init "${user_shell}" >/dev/null 2>&1; then
    if [ -f "${rc_file}" ]; then
      if ( source "${rc_file}" >/dev/null 2>&1 ); then :; fi
    fi
  fi
}

install_requirements_in_env() {
  if command -v conda >/dev/null 2>&1 && conda run -n "${ENV_NAME}" true >/dev/null 2>&1; then
    conda run -n "${ENV_NAME}" python -m pip install --upgrade pip
    conda run -n "${ENV_NAME}" python -m pip install -r "$REQUIREMENTS_FILE"
    return $?
  fi
  if conda activate "${ENV_NAME}" >/dev/null 2>&1; then
    python -m pip install --upgrade pip
    python -m pip install -r "$REQUIREMENTS_FILE"
    return $?
  fi
  return 1
}

ensure_env() {
  configure_conda_channels
  accept_conda_tos_if_supported
  if conda env list | awk '{print $1}' | grep -qx "${ENV_NAME}"; then
    if ! install_requirements_in_env; then
      conda env remove -y -n "${ENV_NAME}" || true
      conda create -y -n "${ENV_NAME}" --override-channels -c conda-forge python=3.11
      if conda run -n "${ENV_NAME}" python -m pip install --upgrade pip >/dev/null 2>&1; then
        conda run -n "${ENV_NAME}" python -m pip install -r "$REQUIREMENTS_FILE"
      fi
    fi
  else
    conda create -y -n "${ENV_NAME}" --override-channels -c conda-forge python=3.11
    if ! install_requirements_in_env; then :; fi
  fi
}

install_nvc_build_deps() {
  local deps="gcc gxx make llvmdev flex pkg-config libffi zlib zstd"
  conda install -y -n "${ENV_NAME}" --override-channels -c conda-forge $deps || return 1
}

main() {
  ensure_conda
  init_conda_shell
  accept_conda_tos_if_supported
  ensure_env
  install_nvc_build_deps
  echo "[MakeConda] Environment '${ENV_NAME}' is ready. Activate with: conda activate ${ENV_NAME}"
}

main "$@"
